# MySQL (Prisma). Example: mysql://USER:PASSWORD@localhost:3306/hivecall
DATABASE_URL="mysql://user:password@localhost:3306/hivecall"

# Shared secret for POST /webhooks/chain-events (Helius, Alchemy Notify, etc.)
WEBHOOK_INGEST_SECRET="change-me"

PORT=3000

